# Build artifacts — large and not useful for agent context
.ruff_cache
build/
vcpkg_installed/
.gradle/
.kotlin/

# But keep C/C++ headers and sources accessible from vcpkg
!build/dev/vcpkg_installed/
!build/dev/vcpkg_installed/**/include/
!build/dev/vcpkg_installed/**/include/**/*.hpp
!build/dev/vcpkg_installed/**/include/**/*.h
!build/dev/vcpkg_installed/**/include/**/*.cpp
!build/dev/vcpkg_installed/**/include/**/*.c
.cache/

# Secrets and credentials
.env
.env.*
!.env.example
*.pem
*.key

# Git internals
.git/
